{
  "name": "testcase-viewer",
  "displayName": "TestCase Viewer",
  "version": "0.0.1",
  "description": "查看线上测试案例",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "csvEditor.testCase",
        "displayName": "测试案例编辑器",
        "selector": [
          {
            "filenamePattern": "*.csv"
          }
        ],
        "priority": "exclusive"
      }
    ],
    "commands": [
      {
        "command": "testcaseViewer.viewOnline",
        "title": "查看测试案例",
        "icon": "$(checklist)"
      },
      {
        "command": "csvEditor.open",
        "title": "用测试案例编辑器打开"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "testcaseViewer.viewOnline",
          "when": "testcaseViewer:showIcon",
          "group": "navigation"
        },
        {
          "command": "csvEditor.open",
          "when": "editorLangId == csv",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "TestCase Viewer",
      "properties": {
        "testcaseViewer.apiUrl": {
          "type": "string",
          "default": "http://localhost:8081",
          "description": "查询线上案例的API接口地址"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "iconv-lite": "^0.7.2",
    "sm-crypto": "^0.3.7",
    "udsv": "^0.7.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.84.0",
    "typescript": "^5.3.0"
  }
}
