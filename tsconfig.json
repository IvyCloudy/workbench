{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "out",
    "lib": ["ES2020", "DOM"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "checkJs": false,
    "types": ["node", "vscode"]
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "media",
    "out",
    "src/**/*.test.ts",
    "src/test",
    "src/core",
    "src/events",
    "src/config",
    "src/services/parsers",
    "src/services/storage",
    "src/services/utils",
    "src/services/http",
    "src/services/index.ts",
    "src/services/store.ts",
    "src/services/http-client.ts",
    "src/services/yaml-parser.ts",
    "src/providers/common/FileParserService.ts"
  ]
}
