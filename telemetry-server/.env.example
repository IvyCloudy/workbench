# ============================================================
# 网关运行所需的环境变量样例（部署时复制为 .env 或注入到容器）
# ============================================================

# 服务监听
HOST=0.0.0.0
PORT=8080

# 鉴权 Token（必填）；多个 Token 用英文逗号分隔便于灰度切换
# 客户端通过 Header `X-Telemetry-Token` 携带
#
# 必须包含两类值：
#   1) 插件包内置兜底 Token（src/services/telemetry.ts 中的 BUILTIN_TELEMETRY_TOKEN）
#      —— 用户零配置即可上报；想封禁老版本流量时把它从此处移除即可
#   2) 后续若由登录接口下发 telemetryToken，把那批动态值也加进来；同样支持灰度/回收
#
# 示例：
#   TELEMETRY_TOKENS=wb-telemetry-2026-221ae433c3920433044f65e0ee0bde03,login-issued-aaaa,login-issued-bbbb
TELEMETRY_TOKENS=wb-telemetry-2026-221ae433c3920433044f65e0ee0bde03

# 限流：单 IP 每分钟最多上报次数；0 表示不限流
RATE_LIMIT_PER_MINUTE=600

# 单批最大事件数（与客户端 MAX_BATCH 对齐即可）
MAX_BATCH_SIZE=100

# body 体最大字节数
MAX_BODY_BYTES=1048576

# MySQL 连接信息
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=telemetry
MYSQL_PASSWORD=please-change-me
MYSQL_DATABASE=workbench_telemetry
MYSQL_POOL_SIZE=10
