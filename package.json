{
  "name": "testcase-viewer",
  "displayName": "TestCase Viewer",
  "version": "0.0.1",
  "description": "查看线上测试案例",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "testcaseViewer.unifiedEditor",
        "displayName": "测试案例编辑器",
        "selector": [
          { "filenamePattern": "**/测试任务/*/测试案例/*.csv" },
          { "filenamePattern": "**/测试任务/*/测试案例/*.yaml" },
          { "filenamePattern": "**/测试任务/*/测试案例/*.yml" },
          { "filenamePattern": "**/测试任务/*/测试案例/*.json" },
          { "filenamePattern": "**/testtask/*/testcase/*.csv" },
          { "filenamePattern": "**/testtask/*/testcase/*.yaml" },
          { "filenamePattern": "**/testtask/*/testcase/*.yml" },
          { "filenamePattern": "**/testtask/*/testcase/*.json" }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "testcaseViewer.viewOnline",
        "title": "查看测试案例",
        "icon": "$(checklist)"
      },
      {
        "command": "testcaseViewer.openWithEditor",
        "title": "用测试案例编辑器打开"
      },
      {
        "command": "testcaseViewer.openWithText",
        "title": "用 Text Editor 打开"
      },
      {
        "command": "testcaseViewer.pushTestCaseFromExplorer",
        "title": "推送测试案例"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "testcaseViewer.viewOnline",
          "when": "testcaseViewer:showIcon",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "testcaseViewer.pushTestCaseFromExplorer",
          "when": "resourcePath =~ /(测试任务|testtask)\\/[^\\/]+\\/(测试案例|testcase)\\/[^\\/]+\\.(csv|yaml|yml|json)$/i",
          "group": "2_workspace"
        }
      ]
    },
    "configuration": {
      "title": "TestCase Viewer",
      "properties": {
        "testcaseViewer.apiUrl": {
          "type": "string",
          "default": "http://localhost:8081",
          "description": "查询线上案例的API接口地址"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "iconv-lite": "^0.7.2",
    "sm-crypto": "^0.3.7",
    "udsv": "^0.7.3",
    "xlsx": "^0.18.5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/vscode": "^1.84.0",
    "typescript": "^5.3.0",
    "vitest": "^2.1.9"
  }
}
