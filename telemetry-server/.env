# ============================================================
# 本地开发用 .env （已在 .gitignore 中，请勿提交）
# 由 scripts/dev-local.sh 加载
# ============================================================

# 服务监听
HOST=127.0.0.1
PORT=8080

# 鉴权 Token；插件兜底 Token 已对齐 .env.example
TELEMETRY_TOKENS=wb-telemetry-2026-221ae433c3920433044f65e0ee0bde03,local-dev-token

# 限流 / 批量
RATE_LIMIT_PER_MINUTE=600
MAX_BATCH_SIZE=100
MAX_BODY_BYTES=1048576

# 本地 MySQL（macOS /usr/local/mysql）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=telemetry
MYSQL_PASSWORD=xxx
MYSQL_DATABASE=workbench_telemetry
MYSQL_POOL_SIZE=10

# 关闭内存模式（=1 时不连 MySQL，仅供无依赖冒烟）
MEMORY_DB=0

NODE_ENV=development
